# Swyftx API
SWYFTX_API_KEY=your_api_key_here
SWYFTX_BASE_URL=https://api.swyftx.com.au
SWYFTX_WS_URL=wss://streaming.swyftx.com.au

# Trading mode — ALWAYS start on paper
PAPER_MODE=true

# Assets to trade (comma-separated)
ASSETS=BTC,ETH
QUOTE_ASSET=AUD

# HMM settings
HMM_CANDLE_RESOLUTION=30
HMM_LOOKBACK_CANDLES=500
HMM_NUM_STATES=3
HMM_RETRAIN_INTERVAL_HOURS=24

# Risk guardrails
MAX_DAILY_LOSS_PCT=2
MAX_DRAWDOWN_PCT=5
MAX_POSITION_SIZE_PCT=10
STOP_LOSS_PCT=2
TAKE_PROFIT_PCT=4

# Engine server
ENGINE_WS_PORT=3001
ENGINE_REST_PORT=3002

# Dashboard
NEXT_PUBLIC_ENGINE_WS_URL=ws://localhost:3001
NEXT_PUBLIC_ENGINE_REST_URL=http://localhost:3002
